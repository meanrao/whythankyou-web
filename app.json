{
  "expo": {
    "name": "Why, Thank You!",
    "slug": "w-ty",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/handbox.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/handbox.png",
      "resizeMode": "contain",
      "backgroundColor": "#2A9D8F"
    },
    "ios": {
