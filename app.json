      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/handbox.png",
        "backgroundColor": "#000000"
      },
      "package": "com.placeholder.app",
      "permissions": [
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
